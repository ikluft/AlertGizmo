<!DOCTYPE html> [% USE HTML %]
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Space Weather Alerts from NOAA SWPC</title>
        [% IF http_refresh.defined %]
        <meta http-equiv="refresh" content="[% http_refresh %]">
        [% END %]
        [%- FOREACH path IN stylesheet %]

        <link rel="stylesheet" href="[% path %]">
        [%- END -%]
    </head>
    <body class="nogrid">
        <div class="space-alert-div">
            <table class="space-alert-table">
                <thead>
                    <tr class="space-alert-row">
                        <th class="space-alert-head" colspan="3">Current NOAA space weather alerts</th>
                    </tr>
                    <tr class="secondary space-alert-row">
                        <th class="space-alert-head">serial</th>
                        <th class="space-alert-head">title</th>
                        <th class="space-alert-head">issued</th>
                    </tr>
                </thead>
                <tbody>
                    [% count = 0 %]
                    [% FOREACH alert_id IN active %]
                    [% alert = alerts.$alert_id %]
                    <tr class="space-alert-row" bgcolor="[% alert.derived.bgcolor %]">
                        [% count = count + 1 %]
                        <td class="space-alert-data">[% alert.derived.serial %]</td>
                        <td class="space-alert-data" title="[% HTML.escape(alert.message) %]">[% HTML.escape(alert.derived.title) %]</td>
                        <td class="space-alert-data" title="begin: [% alert.derived.exists('begin') ? alert.derived.begin : '&cross;' %]&NewLine;end: [% alert.derived.exists('end') ? alert.derived.end : '&cross;' %]"><small>[% alert.derived.issue %]</small></td>
                    </tr>
                    [% END %]
                    [% IF count == 0 %]
                    <tr class="space-alert-row" bgcolor="#bbb">
                        <td class="space-alert-data" colspan="3"><center><b><i>&emptyset;&nbsp;&mdash;&nbsp;no current NOAA SWPC alerts&nbsp;&mdash;&nbsp;&emptyset;</i></b></center></td>
                    </tr>
                    [% END %]
                </tbody>
                <tfoot>
                    <tr class="space-alert-row">
                        <td colspan="2" class="space-alert-data no-border text-left">
                            <small>
                                <a href="[% footer.desc.0 %]" target="_blank">[% footer.desc.1 %]</a>
                                via <a href="[% footer.script.0 %]" target="_blank">[% footer.script.1 %]</a>,
                                by <a href="[% footer.author.0 %]" target="_blank">[% footer.author.1 %]</a>&nbsp;
                            </small>
                        </td>
                        <td colspan="1" class="space-alert-data no-border text-right"><small>[% timestamp %]</small></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </body>
</html>
